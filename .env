# ============================================
# CONFIGURACIÓN PARA DESARROLLO LOCAL
# ============================================

# ============================================
# BASE DE DATOS (PostgreSQL Local en Windows)
# ============================================
# PostgreSQL 18 instalado en C:\Program Files\PostgreSQL\18
# Nota: Los caracteres especiales en la contraseña deben estar codificados para URL
# * = %2A
DATABASE_URL=postgresql://postgres:Gunslinger90+%2A@localhost:5432/yimmenu_auth

# Si tu contraseña es diferente, cámbiala arriba
# Formato: postgresql://usuario:contraseña@localhost:5432/base_de_datos

# ============================================
# CONFIGURACIÓN DEL SERVIDOR
# ============================================
PORT=3000
NODE_ENV=development

# ============================================
# SEGURIDAD
# ============================================
# RSA Private Key (opcional, para firmar privilegios)
# Deja vacío para desarrollo
RSA_PRIVATE_KEY=

# Salt rounds para bcrypt
BCRYPT_SALT_ROUNDS=10

# ============================================
# RATE LIMITING
# ============================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Límite específico para regenerate
REGENERATE_LIMIT_WINDOW_MS=3600000
REGENERATE_MAX_REQUESTS=5

# ============================================
# URLS
# ============================================
API_URL=http://localhost:3000

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=debug
