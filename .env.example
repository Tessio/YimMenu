# Variables de Entorno para Railway (PostgreSQL)
# Copia este archivo a .env y llena los valores

# ============================================
# BASE DE DATOS
# ============================================
# Railway agrega esta variable automáticamente al crear el add-on
DATABASE_URL=postgresql://user:password@host:port/database

# ============================================
# CONFIGURACIÓN DEL SERVIDOR
# ============================================
PORT=3000
NODE_ENV=production

# ============================================
# SEGURIDAD
# ============================================
# RSA Private Key (opcional, para firmar privilegios)
# Genera con: openssl genrsa -out private.pem 2048
RSA_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----
...
-----END RSA PRIVATE KEY-----

# Salt rounds para bcrypt (hash de activation keys)
# Valores recomendados: 10-12 (producción), 8 (desarrollo)
BCRYPT_SALT_ROUNDS=10

# ============================================
# RATE LIMITING
# ============================================
# Límite de peticiones por ventana de tiempo
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Límite específico para regenerate (más estricto)
REGENERATE_LIMIT_WINDOW_MS=3600000
REGENERATE_MAX_REQUESTS=5

# ============================================
# URLS
# ============================================
# URL pública de tu API (para el cliente C++)
API_URL=https://tu-proyecto.up.railway.app

# ============================================
# LOGGING
# ============================================
# Nivel de log: error, warn, info, debug
LOG_LEVEL=info
